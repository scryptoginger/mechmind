{
  "expo": {
    "name": "MechMind",
    "slug": "mechmind",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "mechmind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0b0f14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "local.keithdev.mechmind"
    },
    "android": {
      "package": "local.keithdev.mechmind"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "MechMind",
      "shortName": "MechMind",
      "themeColor": "#0b0f14",
      "backgroundColor": "#0b0f14",
      "display": "standalone"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
